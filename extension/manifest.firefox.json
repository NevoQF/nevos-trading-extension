{
  "action": {
    "default_icon": {
      "16": "assets/icons/logo16.png",
      "32": "assets/icons/logo32.png",
      "48": "assets/icons/logo48.png",
      "64": "assets/icons/logo64.png"
    },
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "scripts": ["background/background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "nevos-trading@nevok.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "content_scripts": [
    {
      "js": ["shared/browser_compat.js", "content/trade_request_bootstrap.js"],
      "matches": ["https://*.roblox.com/trades*", "https://*.roblox.com/*/trades*"],
      "run_at": "document_start"
    },
    {
      "js": ["shared/browser_compat.js", "content/trade_page_themes.js"],
      "matches": ["https://*.roblox.com/trades*", "https://*.roblox.com/*/trades*"],
      "run_at": "document_start"
    },
    {
      "js": ["scripts/trade_list_request_patch.js"],
      "matches": ["https://*.roblox.com/trades*", "https://*.roblox.com/*/trades*"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": ["shared/browser_compat.js", "shared/username_lookup_guard.js", "shared/nte_icon_utils.js", "shared/nte_icons.js", "content/analyze_trade.js", "content/trade_page.js"],
      "matches": [
        "https://*.roblox.com/trades*",
        "https://*.roblox.com/*/trades*",
        "https://*.roblox.com/users/*/trade*",
        "https://*.roblox.com/*/users/*/trade*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": ["shared/browser_compat.js", "shared/username_lookup_guard.js", "shared/nte_icon_utils.js", "shared/nte_icons.js", "content/catalog_page.js", "content/catalog_item_intel.js"],
      "matches": [
        "https://*.roblox.com/catalog/*",
        "https://*.roblox.com/*/catalog/*",
        "https://*.roblox.com/catalog*",
        "https://*.roblox.com/*/catalog*",
        "https://*.roblox.com/bundles/*",
        "https://*.roblox.com/*/bundles/*",
        "https://*.roblox.com/bundles*",
        "https://*.roblox.com/*/bundles*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": ["shared/browser_compat.js", "shared/username_lookup_guard.js", "shared/nte_icon_utils.js", "shared/nte_icons.js", "content/user_profile_page.js"],
      "matches": [
        "https://*.roblox.com/users/*/profile*",
        "https://*.roblox.com/*/users/*/profile*",
        "https://*.roblox.com/users/*/inventory*",
        "https://*.roblox.com/*/users/*/inventory*"
      ],
      "run_at": "document_idle"
    },
    {
      "all_frames": true,
      "js": ["shared/browser_compat.js", "content/roblox_totp_autofill.js"],
      "matches": ["https://*.roblox.com/*", "https://roblox.com/*"],
      "run_at": "document_idle"
    },
    {
      "js": ["shared/browser_compat.js", "content/navbar_quick_search.js"],
      "matches": ["https://*.roblox.com/*", "https://roblox.com/*"],
      "run_at": "document_idle"
    }
  ],
  "description": "Trading-focused Roblox extension with values, inbound filters, inventory search, and profile utilities.",
  "host_permissions": [
    "https://api.rolimons.com/*",
    "https://www.rolimons.com/*",
    "https://rolimons.com/*",
    "https://routility.io/*",
    "https://roautotrade.com/*",
    "https://nevos-extension.com/*",
    "https://www.nevos-extension.com/*",
    "https://*.roblox.com/*",
    "https://roblox.com/*",
    "https://thumbnails.roblox.com/*"
  ],
  "icons": {
    "128": "assets/icons/logo128.png",
    "16": "assets/icons/logo16.png",
    "32": "assets/icons/logo32.png",
    "48": "assets/icons/logo48.png",
    "64": "assets/icons/logo64.png"
  },
  "manifest_version": 3,
  "name": "Nevos Trading Extension",
  "options_ui": {
    "open_in_tab": true,
    "page": "popup/popup.html"
  },
  "permissions": ["storage", "alarms", "notifications"],
  "short_name": "Nevos Trade",
  "version": "3.10.33",
  "web_accessible_resources": [
    {
      "matches": ["https://*.roblox.com/*"],
      "resources": [
        "assets/Averta.otf",
